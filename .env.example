# ============================================================
#  LogMax — Variáveis de ambiente
#  Copie este ficheiro para `.env` e preencha os valores reais.
#  NUNCA commit o `.env` (está no .gitignore).
# ============================================================

# Supabase — credenciais públicas (expostas ao browser via VITE_*)
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Supabase — chave server-only (NUNCA expor ao cliente; usado em /api/*)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Secret HMAC dedicado para tokens QR de ponto (separado do service_role
# para limitar blast radius se vazar). Gerar com:
#   openssl rand -hex 32
QR_TOKEN_SECRET=

# URL pública da app — usado para validar CORS Origin nos endpoints sensíveis.
# Em desenvolvimento, o CORS já aceita localhost:3000/3001/5173 automaticamente.
VITE_APP_URL=https://seu-dominio.vercel.app

# Gemini API key (opcional — usado em funcionalidades de IA)
GEMINI_API_KEY=
